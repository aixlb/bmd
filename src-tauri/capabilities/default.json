{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "bmd 主窗口默认权限（最小化：fs 具体路径经 dialog 动态授权）",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "dialog:default",
    "fs:default"
  ]
}
